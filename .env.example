PORT=8787
LOG_LEVEL=info
SF_API_URL=https://simplefunctions.dev

# Required for authenticated portfolio/intents/runtime/live execution.
# Public research works without it.
SF_API_KEY=
SF_CLOUD_KEY=
CONTROL_TOKEN=

# Default loop mode is paper. Live needs all three:
# EXECUTION_MODE=live
# ENABLE_LIVE_TRADING=true
# CONFIRM_LIVE_TRADING=I_UNDERSTAND_THIS_PLACES_REAL_ORDERS
EXECUTION_MODE=paper
ENABLE_LIVE_TRADING=false
CONFIRM_LIVE_TRADING=

# US users should keep Polymarket live execution blocked.
JURISDICTION=US
BLOCK_POLYMARKET_LIVE=true

DEFAULT_INTERVAL_MS=60000
DATA_DIR=/app/data
